{
  "name": "secureclaw",
  "version": "1.0.0",
  "description": "Enterprise AI Agent security framework — runs Claude Code agents in isolated containers with 6-layer security",
  "main": "dist/core/index.js",
  "scripts": {
    "build": "tsc --noEmit && tsc",
    "dev": "tsx watch src/core/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node dist/core/index.js",
    "verify-audit": "node dist/audit/backend/local-audit.js --verify"
  },
  "keywords": ["ai-agent", "security", "claude", "sandbox", "multi-channel", "discord", "telegram", "slack", "whatsapp"],
  "author": "Alex647648",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alex647648/secureclaw.git"
  },
  "bugs": {
    "url": "https://github.com/Alex647648/secureclaw/issues"
  },
  "homepage": "https://github.com/Alex647648/secureclaw#readme",
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.71",
    "@slack/bolt": "^4.6.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "grammy": "^1.40.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

# SecureClaw 环境变量模板
# 复制为 secureclaw.env 并填入实际值：cp secureclaw.env.example secureclaw.env

# ── Claude 认证（必填）──
ANTHROPIC_API_KEY=sk-ant-xxx

# ── WhatsApp（默认启用）──
# 认证数据由 setup 自动生成到 scdata/whatsapp-auth/，无需手动配置

# ── Telegram（可选）──
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ── Slack（可选）──
# SLACK_BOT_TOKEN=xoxb-xxx
# SLACK_APP_TOKEN=xapp-xxx

# ── Discord（可选）──
# DISCORD_BOT_TOKEN=xxx

# ── 通用配置 ──
# ASSISTANT_NAME=SecureClaw     # 触发词中的助手名
# CONTAINER_RUNTIME=apple       # apple | docker
# LOG_LEVEL=info                # debug | info | warn | error
